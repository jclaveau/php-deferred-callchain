{
    "name": "jclaveau/php-deferred-callchain",
    "description": "Register a chain of calls that will be applied on an instance later",
    "license": "MIT",
    "type": "library",
    "keywords": ["asynchronous", "fluent", "chain", "calls", "future", "promise", "lazy", "later", "php", "php7", "php8"],
    "authors": [
        {
            "name": "Jean Claveau",
            "role": "Developer"
        }
    ],
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "JClaveau\\Async\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "require": {
        "php": "^8.0",
        "jclaveau/php-fluent-trait": "^1.1",
        "jclaveau/php-visibility-violator": "^1.0 || ^2.0"
    }
}
